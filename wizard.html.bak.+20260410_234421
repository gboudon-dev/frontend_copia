<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Prospecta v2 — Generador de Informes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap"
    onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
  </noscript>
  <style>
    :root {
      --periwinkle: #8B9FD4;
      --periwinkle-dark: #6B80B4;
      --durazno: #F4A261;
      --bg: #0D1117;
      --bg-card: #161B22;
      --bg-input: #1C2128;
      --text: #C9D1D9;
      --text-muted: #8895A8;
      --text-bright: #FFFFFF;
      --green: #7FB99A;
      --red: #C97B8A;
      --radius: 8px;
      --font: 'Inter', -apple-system, sans-serif;
      --font-display: 'Sora', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    header {
      width: 100%;
      padding: 1.5rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid #21262D;
    }
    header h1 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      color: var(--periwinkle);
    }
    header .version {
      font-size: 0.75rem;
      color: var(--text-muted);
      background: var(--bg-card);
      padding: 2px 8px;
      border-radius: 4px;
    }
    .stepper {
      display: flex;
      gap: 0;
      margin: 2rem 0 1rem;
      width: 100%;
      max-width: 700px;
      justify-content: center;
    }
    .stepper .s {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1rem;
      font-size: 0.85rem;
      color: var(--text-muted);
      border-bottom: 2px solid transparent;
      transition: all 0.3s;
    }
    .stepper .s.active { color: var(--periwinkle); border-color: var(--periwinkle); }
    .stepper .s.done { color: var(--green); border-color: var(--green); }
    .stepper .s .num {
      width: 22px; height: 22px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; font-weight: 600;
      background: var(--bg-card);
      border: 1px solid currentColor;
    }
    main {
      width: 100%;
      max-width: 700px;
      padding: 0 1.5rem 3rem;
    }
    .step { display: none; }
    .step.active { display: block; animation: fadeIn 0.3s; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

    h2 { font-family: var(--font-display); font-size: 1.1rem; color: var(--text-bright); margin-bottom: 1rem; }
    label { display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem; }
    input, textarea {
      width: 100%;
      padding: 0.7rem 0.9rem;
      background: var(--bg-input);
      border: 1px solid #30363D;
      border-radius: var(--radius);
      color: var(--text);
      font-family: var(--font);
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, textarea:focus { border-color: var(--periwinkle); }
    textarea { resize: vertical; min-height: 100px; }
    .field { margin-bottom: 1.2rem; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.65rem 1.5rem;
      border: none; border-radius: var(--radius);
      font-family: var(--font); font-size: 0.9rem; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
    }
    .btn-primary { background: var(--periwinkle); color: var(--bg); }
    .btn-primary:hover { background: var(--periwinkle-dark); }
    .btn-secondary { background: transparent; color: var(--periwinkle); border: 1px solid var(--periwinkle); }
    .btn-secondary:hover { background: rgba(139,159,212,0.1); }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-row { display: flex; gap: 0.8rem; margin-top: 1.5rem; }
    .error { color: var(--red); font-size: 0.85rem; margin-top: 0.5rem; }

    /* Plan cards */
    .plan-card {
      background: var(--bg-card);
      border: 1px solid #30363D;
      border-radius: var(--radius);
      padding: 1rem;
      margin-bottom: 0.8rem;
    }
    .plan-card h3 { font-size: 0.95rem; color: var(--text-bright); margin-bottom: 0.5rem; }
    .plan-card .chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.5rem; }
    .chip {
      font-size: 0.75rem;
      padding: 2px 8px;
      border-radius: 4px;
      background: rgba(139,159,212,0.15);
      color: var(--periwinkle);
    }
    .plan-card .query { font-size: 0.8rem; color: var(--text-muted); }
    .plan-title {
      font-family: var(--font-display);
      font-size: 1rem;
      color: var(--durazno);
      margin-bottom: 1rem;
    }

    /* Progress */
    .progress-item {
      display: flex; align-items: center; gap: 0.8rem;
      padding: 0.6rem 0;
      border-bottom: 1px solid #21262D;
    }
    .progress-item .icon { font-size: 1rem; width: 24px; text-align: center; }
    .progress-item .label { flex: 1; font-size: 0.9rem; }
    .progress-bar {
      width: 100%;
      height: 4px;
      background: var(--bg-input);
      border-radius: 2px;
      margin: 1rem 0;
      overflow: hidden;
    }
    .progress-bar .fill {
      height: 100%;
      background: var(--periwinkle);
      transition: width 0.5s;
      border-radius: 2px;
    }
    .status-text { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem; }
    .result-actions { margin-top: 1.5rem; }
    .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid var(--text-muted); border-top-color: var(--periwinkle); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

<header>
  <h1>Prospecta</h1>
  <span class="version">Generador v2</span>
</header>

<div class="stepper">
  <div class="s active" id="stepper-1"><span class="num">1</span> Login</div>
  <div class="s" id="stepper-2"><span class="num">2</span> Tema</div>
  <div class="s" id="stepper-3"><span class="num">3</span> Plan</div>
  <div class="s" id="stepper-4"><span class="num">4</span> Generar</div>
</div>

<main>
  <!-- Step 1: Login -->
  <div id="step-login" class="step active">
    <h2>Iniciar sesion</h2>
    <div class="field">
      <label for="username">Usuario</label>
      <input type="text" id="username" placeholder="nacho" autocomplete="username">
    </div>
    <div class="field">
      <label for="password">Contrasena</label>
      <input type="password" id="password" placeholder="••••••" autocomplete="current-password">
    </div>
    <div id="login-error" class="error"></div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="login()">Entrar</button>
    </div>
  </div>

  <!-- Step 2: Tema -->
  <div id="step-tema" class="step">
    <h2>Describe el informe</h2>
    <div class="field">
      <label for="prompt">Objetivo del informe</label>
      <textarea id="prompt" rows="4" placeholder="Ej: Informe de tendencias de capital humano en Region de Coquimbo para el CPR, con foco en mineria, agricultura y turismo"></textarea>
    </div>
    <div class="field">
      <label for="contexto">Contexto adicional (opcional)</label>
      <textarea id="contexto" rows="3" placeholder="Ej: Preguntas de panelistas, prioridades especificas, datos complementarios..."></textarea>
    </div>
    <div id="tema-error" class="error"></div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="submitTema()" id="btn-plan">Generar plan</button>
    </div>
  </div>

  <!-- Step 3: Plan -->
  <div id="step-plan" class="step">
    <h2>Plan del informe</h2>
    <div id="plan-title" class="plan-title"></div>
    <div id="plan-sections"></div>
    <div id="plan-errors" class="error"></div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="approvePlan()">Aprobar y generar</button>
      <button class="btn btn-secondary" onclick="goToStep(2)">Modificar tema</button>
    </div>
  </div>

  <!-- Step 4: Generacion -->
  <div id="step-generate" class="step">
    <h2>Generando informe...</h2>
    <div class="progress-bar"><div class="fill" id="progress-fill" style="width:0%"></div></div>
    <div class="status-text" id="status-text">Iniciando...</div>
    <div id="progress-sections"></div>
    <div id="result-area" class="result-actions" style="display:none">
      <h2>Informe listo</h2>
      <p style="color: var(--green); margin-bottom: 1rem;">PDF generado exitosamente.</p>
      <div class="btn-row">
        <button class="btn btn-primary" onclick="newReport()">Nuevo informe</button>
      </div>
    </div>
  </div>
</main>

<script>
const API = '/api/v2';
let token = '';
let currentPlan = null;
let currentJobId = '';
let pollInterval = null;

async function apiFetch(path, options = {}) {
  const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
  if (token) headers['Authorization'] = 'Bearer ' + token;
  const resp = await fetch(API + path, { ...options, headers });
  return resp;
}

function goToStep(n) {
  document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
  document.getElementById(['','step-login','step-tema','step-plan','step-generate'][n]).classList.add('active');
  document.querySelectorAll('.stepper .s').forEach((s, i) => {
    s.classList.remove('active', 'done');
    if (i + 1 === n) s.classList.add('active');
    else if (i + 1 < n) s.classList.add('done');
  });
}

async function login() {
  const username = document.getElementById('username').value.trim();
  const password = document.getElementById('password').value;
  const errEl = document.getElementById('login-error');
  errEl.textContent = '';

  if (!username || !password) { errEl.textContent = 'Ingresa usuario y contrasena'; return; }

  try {
    const resp = await apiFetch('/auth/login', {
      method: 'POST',
      body: JSON.stringify({ username, password }),
    });
    if (!resp.ok) { errEl.textContent = 'Credenciales invalidas'; return; }
    const data = await resp.json();
    token = data.token;
    goToStep(2);
  } catch (e) {
    errEl.textContent = 'Error de conexion: ' + e.message;
  }
}

async function submitTema() {
  const prompt = document.getElementById('prompt').value.trim();
  const contexto = document.getElementById('contexto').value.trim();
  const errEl = document.getElementById('tema-error');
  const btn = document.getElementById('btn-plan');
  errEl.textContent = '';

  if (!prompt) { errEl.textContent = 'Describe el objetivo del informe'; return; }

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Planificando...';

  try {
    const resp = await apiFetch('/plan', {
      method: 'POST',
      body: JSON.stringify({ prompt, contexto }),
    });
    if (!resp.ok) {
      const err = await resp.json();
      errEl.textContent = err.detail || 'Error generando plan';
      return;
    }
    const data = await resp.json();
    currentPlan = data.plan;
    renderPlan(currentPlan);
    goToStep(3);
  } catch (e) {
    errEl.textContent = 'Error: ' + e.message;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Generar plan';
  }
}

function renderPlan(plan) {
  document.getElementById('plan-title').textContent = plan.titulo_sugerido || 'Sin titulo';
  const container = document.getElementById('plan-sections');
  container.innerHTML = '';

  (plan.secciones || []).forEach((sec, i) => {
    const card = document.createElement('div');
    card.className = 'plan-card';
    card.innerHTML = `
      <h3>${i + 1}. ${sec.titulo || 'Sin titulo'}</h3>
      <div class="chips">${(sec.bloques || []).map(b => `<span class="chip">${b}</span>`).join('')}</div>
      <div class="query">Busqueda: ${sec.query_rag || '-'}</div>
    `;
    container.appendChild(card);
  });

  if (plan.bloques_globales && plan.bloques_globales.length) {
    const globalCard = document.createElement('div');
    globalCard.className = 'plan-card';
    globalCard.innerHTML = `
      <h3>Bloques globales</h3>
      <div class="chips">${plan.bloques_globales.map(b => `<span class="chip">${b}</span>`).join('')}</div>
    `;
    container.appendChild(globalCard);
  }
}

async function approvePlan() {
  if (!currentPlan) return;

  goToStep(4);
  const sections = currentPlan.secciones || [];
  const container = document.getElementById('progress-sections');
  container.innerHTML = '';
  sections.forEach((sec, i) => {
    const item = document.createElement('div');
    item.className = 'progress-item';
    item.id = 'progress-sec-' + i;
    item.innerHTML = `
      <span class="icon">&#9711;</span>
      <span class="label">${sec.titulo}</span>
    `;
    container.appendChild(item);
  });

  try {
    const resp = await apiFetch('/generate', {
      method: 'POST',
      body: JSON.stringify({
        plan: currentPlan,
        report_goal: document.getElementById('prompt').value.trim(),
      }),
    });
    if (!resp.ok) {
      document.getElementById('status-text').textContent = 'Error iniciando generacion';
      return;
    }
    const data = await resp.json();
    currentJobId = data.job_id;
    pollInterval = setInterval(pollStatus, 3000);
  } catch (e) {
    document.getElementById('status-text').textContent = 'Error: ' + e.message;
  }
}

async function pollStatus() {
  if (!currentJobId) return;

  try {
    const resp = await apiFetch('/status/' + currentJobId);
    if (!resp.ok) return;
    const data = await resp.json();

    document.getElementById('status-text').textContent = data.progress;

    const total = data.sections_total || 1;
    const done = data.sections_done || 0;
    const pct = data.status === 'completed' ? 100 : Math.round((done / total) * 90);
    document.getElementById('progress-fill').style.width = pct + '%';

    // Update section icons
    const sections = currentPlan.secciones || [];
    sections.forEach((sec, i) => {
      const el = document.getElementById('progress-sec-' + i);
      if (!el) return;
      const icon = el.querySelector('.icon');
      if (i < done) { icon.textContent = '\u2713'; icon.style.color = 'var(--green)'; }
      else if (i === done && data.status === 'running') { icon.innerHTML = '<span class="spinner"></span>'; }
    });

    if (data.status === 'completed') {
      clearInterval(pollInterval);
      document.getElementById('progress-fill').style.width = '100%';
      document.getElementById('status-text').textContent = 'Completado';
      document.getElementById('result-area').style.display = 'block';
      document.querySelector('#step-generate h2').textContent = 'Informe generado';
    } else if (data.status === 'error') {
      clearInterval(pollInterval);
      document.getElementById('status-text').textContent = 'Error: ' + data.error;
      document.getElementById('progress-fill').style.background = 'var(--red)';
    }
  } catch (e) {
    // Retry silently
  }
}

function newReport() {
  currentPlan = null;
  currentJobId = '';
  document.getElementById('prompt').value = '';
  document.getElementById('contexto').value = '';
  goToStep(2);
}

// Enter key support
document.getElementById('password').addEventListener('keydown', e => { if (e.key === 'Enter') login(); });
document.getElementById('prompt').addEventListener('keydown', e => { if (e.key === 'Enter' && e.ctrlKey) submitTema(); });
</script>
</body>
</html>
