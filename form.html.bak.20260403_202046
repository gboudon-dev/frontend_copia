<script>
  // ===== VIEW NAVIGATION =====
  function switchView(view) {
    document.querySelectorAll('.nav-tab').forEach(t => t.classList.toggle('active', t.dataset.view === view));
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    document.getElementById('view-' + view).classList.add('active');

    if (view === 'about') {
      animateAboutEntrance();
      animateCounters();
    }
  }

  document.querySelectorAll('.nav-tab').forEach(tab => {
    tab.addEventListener('click', () => switchView(tab.dataset.view));
  });

  // ===== ABOUT ENTRANCE ANIMATIONS =====
  function animateAboutEntrance() {
    const sections = document.querySelectorAll('#view-about .about-section');
    sections.forEach((s, i) => {
      s.classList.remove('visible');
      setTimeout(() => s.classList.add('visible'), 80 * i);
    });
  }

  // ===== COUNTER ANIMATION =====
  let countersAnimated = false;
  function animateCounters() {
    if (countersAnimated) return;
    countersAnimated = true;
    document.querySelectorAll('.stat-number[data-target]').forEach(el => {
      const target = parseInt(el.dataset.target);
      const duration = 1200;
      const start = performance.now();
      function tick(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(target * eased);
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  }

  // ===== FORM: AUDIENCE TOGGLE =====
  const audienceSelect = document.getElementById('audience');
  const otroText = document.getElementById('otro-text');

  audienceSelect.addEventListener('change', () => {
    otroText.style.display = audienceSelect.value === 'otro' ? 'block' : 'none';
    if (audienceSelect.value === 'otro') otroText.focus();
  });

  // ===== PROGRESS TRACKER =====
  const PHASES = [
    { label: 'Consultando base de conocimiento', duration: 15000 },
    { label: 'Planificando estructura del informe', duration: 30000 },
    { label: 'Redactando secciones', duration: 90000 },
    { label: 'Generando resumen ejecutivo', duration: 30000 },
    { label: 'Convirtiendo a PDF y subiendo', duration: 15000 }
  ];

  const FUN_FACTS = [
    'Prospecta analiza fuentes de más de 15 países de Latinoamérica',
    'Cada informe consulta automáticamente la base de conocimiento institucional',
    'Los agentes de IA trabajan en equipo para estructurar cada sección',
    'El sistema identifica tendencias relevantes para las carreras de INACAP',
    'Prospecta transforma información dispersa en inteligencia estratégica',
    'Cada sección se enriquece con evidencia de fuentes verificadas',
    'El informe final queda disponible en Nextcloud para todo el equipo',
    'La inteligencia prospectiva anticipa cambios antes de que ocurran'
  ];

  let progressTimers = [];
  let factInterval = null;
  let currentPhase = -1;

  function startProgress() {
    const tracker = document.getElementById('progress-tracker');
    const steps = document.querySelectorAll('#timeline li');
    const fill = document.getElementById('progress-fill');
    const percent = document.getElementById('progress-percent');
    const factEl = document.getElementById('fun-fact');

    tracker.style.display = 'block';
    currentPhase = -1;

    steps.forEach(s => { s.className = 'pending'; });
    fill.style.width = '0%';
    percent.textContent = '0%';

    const totalDuration = PHASES.reduce((sum, p) => sum + p.duration, 0);
    let elapsed = 0;

    PHASES.forEach((phase, i) => {
      const timer = setTimeout(() => {
        currentPhase = i;
        steps.forEach((s, j) => {
          if (j < i) s.className = 'done';
          else if (j === i) s.className = 'active';
          else s.className = 'pending';
        });
      }, elapsed);
      progressTimers.push(timer);

      const phaseStart = elapsed;
      const phaseEnd = elapsed + phase.duration;
      const startPct = (phaseStart / totalDuration) * 100;
      const endPct = (phaseEnd / totalDuration) * 100;

      const ticks = Math.floor(phase.duration / 500);
      for (let t = 0; t <= ticks; t++) {
        const tickTimer = setTimeout(() => {
          const pct = startPct + ((endPct - startPct) * (t / ticks));
          fill.style.width = Math.min(pct, 95) + '%';
          percent.textContent = Math.round(Math.min(pct, 95)) + '%';
        }, phaseStart + (t * 500));
        progressTimers.push(tickTimer);
      }

      elapsed += phase.duration;
    });

    const doneTimer = setTimeout(() => {
      steps.forEach(s => { s.className = 'done'; });
      fill.style.width = '100%';
      percent.textContent = '100%';
      factEl.style.opacity = '0';
      if (factInterval) { clearInterval(factInterval); factInterval = null; }
      setTimeout(() => {
        tracker.style.display = 'none';
        document.getElementById('status-success').style.display = 'block';
        document.getElementById('submit-btn').textContent = 'Solicitud enviada';
      }, 1500);
    }, elapsed);
    progressTimers.push(doneTimer);

    let factIndex = Math.floor(Math.random() * FUN_FACTS.length);
    factEl.style.opacity = '1';
    factEl.textContent = FUN_FACTS[factIndex];

    factInterval = setInterval(() => {
      factEl.style.opacity = '0';
      setTimeout(() => {
        factIndex = (factIndex + 1) % FUN_FACTS.length;
        factEl.textContent = FUN_FACTS[factIndex];
        factEl.style.opacity = '1';
      }, 500);
    }, 6000);
  }

  function stopProgress(success) {
    progressTimers.forEach(t => clearTimeout(t));
    progressTimers = [];
    if (factInterval) { clearInterval(factInterval); factInterval = null; }

    const tracker = document.getElementById('progress-tracker');
    const steps = document.querySelectorAll('#timeline li');
    const fill = document.getElementById('progress-fill');
    const percent = document.getElementById('progress-percent');
    const factEl = document.getElementById('fun-fact');

    if (success) {
      steps.forEach(s => { s.className = 'done'; });
      fill.style.width = '100%';
      percent.textContent = '100%';
      factEl.style.opacity = '0';
      setTimeout(() => { tracker.style.display = 'none'; }, 1500);
    } else {
      tracker.style.display = 'none';
    }
  }

  // ===== FORM SUBMIT =====
  document.getElementById('form').addEventListener('submit', async (e) => {
    e.preventDefault();

    const btn = document.getElementById('submit-btn');
    const success = document.getElementById('status-success');
    const error = document.getElementById('status-error');
    const errorMsg = document.getElementById('error-msg');

    [success, error].forEach(el => el.style.display = 'none');
    document.getElementById('progress-tracker').style.display = 'none';

    let audience = audienceSelect.value;
    if (audience === 'otro') {
      audience = otroText.value.trim() || 'equipo interno';
    }

    const payload = {
      report_goal: document.getElementById('report_goal').value.trim(),
      audience,
      tone: document.getElementById('tone').value,
      desired_length: document.getElementById('desired_length').value,
      min_palabras: '400',
      max_palabras: '600'
    };

    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      const res = await fetch('/api/generar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const data = await res.json();

      if (res.ok) {
        btn.textContent = 'Generando...';
        startProgress();
      } else {
        errorMsg.textContent = data.message || data.error || `Error ${res.status}`;
        error.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Generar informe';
      }
    } catch (err) {
      errorMsg.textContent = 'No se pudo conectar con el servidor. Verifica tu conexión a la red INACAP.';
      error.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Generar informe';
    }
  });
</script>

